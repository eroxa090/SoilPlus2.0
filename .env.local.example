# --- Copy to .env.local and fill in real values (never commit .env.local) ---

# Supabase — production database for users + orders.
# Your project: SoilPlus2.0
SUPABASE_URL=https://wpetubtrcurxbdtqudyh.supabase.co
# Service-role key (Project -> Settings -> API -> "service_role" secret).
# NEVER expose this to the browser. Only used in server-side API routes.
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here

# Google Gemini — /api/chat, /api/diagnose, /api/forecast.
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=paste_gemini_key_here

# OpenWeatherMap — /api/weather. https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=paste_openweathermap_key_here

# 32-byte random HMAC secret for session cookies.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_with_32_random_bytes
